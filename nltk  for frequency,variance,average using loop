EX NO:4A CONDITIONAL FREQUENCY DISTRIBUTION

import pandas as pd
import numpy as np
import nltk
from nltk.probability import ConditionalFreqDist

# Step 1: Define items with categories
items = [
    ('F', 'Apple'),
    ('F', 'Banana'),
    ('F', 'Orange'),
    ('V', 'Carrot'),
    ('V', 'Tomato'),
    ('V', 'Potato'),
    ('F', 'Apple'),
    ('V', 'Carrot'),
    ('F', 'Banana'),
    ('V', 'Tomato')
]

# Step 2: Build Conditional Frequency Distribution
cfd = ConditionalFreqDist(items)

# Step 3: Display frequencies
print("Conditional Frequency Distribution:\n")
for category in cfd.conditions():
    print(f"Category: {category}")
    for item in cfd[category]:
        print(f"  {item}: {cfd[category][item]}")

# Step 4: Convert to DataFrame for tabular view
df = pd.DataFrame(dict((category, dict(cfd[category])) for category in cfd.conditions()))
print("\nTabular View:\n")

