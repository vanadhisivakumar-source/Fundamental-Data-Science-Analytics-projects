EX NO: 5A CREATE NORMAL CURVE

from scipy.stats import norm
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sb

# Generate data points
data = np.arange(1, 10, 0.01)

# Normal distribution PDF with mean=5.3 and std=1
pdf = norm.pdf(data, loc=5.3, scale=1)

# Plot using seaborn
sb.set_style('whitegrid')
sb.lineplot(x=data, y=pdf, color='black')

# Labels
plt.xlabel('Heights')
plt.ylabel('Probability Density')
plt.title('Normal Distribution Curve')

plt.show()

EX NO: 5B CORRELATION AND SCATTER PLOTS


import numpy as np
import matplotlib.pyplot as plt
import pandas as pd

# Data
y = pd.Series([1, 2, 3, 4, 3, 5, 4])
x = pd.Series([1, 2, 3, 4, 5, 6, 7])

# Correlation coefficient
correlation = y.corr(x)
print("Correlation:", correlation)

# Scatter plot
plt.scatter(x, y)

# Best-fit line (linear regression)
plt.plot(
    np.unique(x),
    np.poly1d(np.polyfit(x, y, 1))(np.unique(x)),
    color='red'
)

plt.xlabel("X values")
plt.ylabel("Y values")
plt.title("Correlation and Scatter Plot with Best-fit Line")
plt.show()


