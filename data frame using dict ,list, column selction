CREATE A DATAFRAME USING A LIST OF ELEMENTS 

import pandas as pd  # Import pandas only once

# List of strings
lst = ['A', 'B', 'C', 'D', 'E', 'F', 'G']

# Create DataFrame from list
df = pd.DataFrame(lst, columns=['Letters'])  # Optional: name the column

# Display the DataFrame
print(df)


EX NO: 2B 	CREATE A DATAFRAME USING THE DICTIONARY 

import pandas as pd  # Import pandas library

# Initialise data of lists
data = {
    'Name': ['Tom', 'nick', 'krish', 'jack'],
    'Age': [20, 21, 19, 18]
}

# Create DataFrame
df = pd.DataFrame(data)

# Print the output
print(df)

EX NO: 2C 	COLUMN SELECTION 

import pandas as pd  

# Define a dictionary containing employee data
data = {
    'Name': ['Jai', 'Princi', 'Gaurav', 'Anuj'],
    'Age': [27, 24, 22, 32],
    'Address': ['Delhi', 'Kanpur', 'Allahabad', 'Kannauj'],
    'Qualification': ['Msc', 'MA', 'MCA', 'Phd']
}

# Convert the dictionary into DataFrame
df = pd.DataFrame(data)

# Display the full DataFrame
print("Full DataFrame:")
print(df)

# Select and display only 'Name' and 'Qualification' columns
print("\nSelected Columns:")
print(df[['Name', 'Qualification']])

