EX NO: 2E 	DROPPING MISSING VALUES USING DROPNA() 

# Importing pandas and numpy
import pandas as pd
import numpy as np

# Dictionary of lists with some NaN values
data = {
    'First Score': [100, 90, np.nan, 95],
    'Second Score': [30, np.nan, 45, 56],
    'Third Score': [52, 40, 80, 98],
    'Fourth Score': [np.nan, np.nan, np.nan, 65]
}

# Creating a DataFrame from dictionary
df = pd.DataFrame(data)

print("Original DataFrame:\n", df, "\n")

# Dropping rows with at least one NaN value
df_cleaned = df.dropna()

print("DataFrame after dropping rows with at least one NaN value:\n", df_cleaned)
